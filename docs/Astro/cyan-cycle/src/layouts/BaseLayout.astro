---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
---

<html lang="en" class="dark scroll-smooth">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
        <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{Astro.props.pageTitle || "Astro Portfolio"}</title>
    </head>
    <body
        class="bg-gray-950 text-gray-200 min-h-screen flex flex-col font-sans antialiased selection:bg-cyan-500/30"
    >
        <Header />
        <main class="grow w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <slot />
        </main>
        <Footer />
    </body>
</html>
