---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Sobre Mí";
const identity = {
	nombre: "Abde",
	pueblo: "Almoradí",
	provincia: "Alicante",
	pais: "España",
	profesion: "Programador",
	hobbies: ["Fútbol ⚽", "Baloncesto 🏀", "Videojuegos 🎮"],
};

const skills = ["HTML/CSS", "JavaScript", "Astro", "TailwindCSS", "Figma"];
---

<BaseLayout pageTitle={pageTitle}>
	<section class="max-w-5xl mx-auto py-12 px-4 sm:px-6">
		<div class="text-center mb-16 relative">
			<div
				class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-32 h-32 bg-cyan-500/30 rounded-full blur-[60px] -z-10"
			>
			</div>
			<h1
				class="text-5xl md:text-6xl font-extrabold tracking-tight mb-4 text-white"
			>
				<span
					class="text-transparent bg-clip-text bg-linear-to-r from-cyan-400 to-blue-500"
					>Sobre</span
				> Mí
			</h1>
			<p class="text-gray-400 text-lg max-w-2xl mx-auto">
				Conoce un poco más sobre quién soy, de dónde vengo y qué me
				apasiona hacer.
			</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-left">
			<!-- Personal Info Card -->
			<div
				class="md:col-span-2 bg-gray-900/50 backdrop-blur-sm border border-gray-800 rounded-3xl p-8 hover:border-cyan-500/30 transition-colors duration-300 relative overflow-hidden group"
			>
				<div
					class="absolute top-0 right-0 w-32 h-32 bg-blue-500/10 rounded-bl-full blur-2xl group-hover:bg-cyan-500/20 transition-all duration-500"
				>
				</div>

				<h2
					class="text-2xl font-bold text-white mb-6 flex items-center gap-3"
				>
					<svg
						class="w-6 h-6 text-cyan-400"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
						><path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
						></path></svg
					>
					¿Quién soy?
				</h2>

				<div class="space-y-4 text-gray-300 text-lg leading-relaxed">
					<p>
						Me llamo <strong class="text-white font-semibold"
							>{identity.nombre}</strong
						>. Vivo en <span
							>{identity.pueblo}, {identity.provincia}</span
						> y trabajo como <strong
							class="text-transparent bg-clip-text bg-linear-to-r from-cyan-400 to-blue-400 font-bold"
							>{identity.profesion}</strong
						>.
					</p>
					<p>
						Me apasiona el desarrollo web y el diseño de interfaces
						limpias, modernas y funcionales. Disfruto construyendo
						herramientas que aportan valor y creando experiencias de
						usuario memorables. Comparto mis conocimientos y busco
						siempre aprender algo nuevo.
					</p>
				</div>

				<div class="mt-8 flex flex-wrap gap-4">
					<div
						class="flex items-center gap-2 bg-gray-800/50 rounded-full px-4 py-2 border border-gray-700/50"
					>
						<svg
							class="w-4 h-4 text-gray-400"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
							><path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
							></path></svg
						>
						<span class="text-sm text-gray-300"
							>{identity.pais}</span
						>
					</div>
				</div>
			</div>

			<!-- Hobbies Column -->
			<div
				class="bg-gray-900/50 backdrop-blur-sm border border-gray-800 rounded-3xl p-8 hover:border-cyan-500/30 transition-colors duration-300 relative overflow-hidden group"
			>
				<div
					class="absolute -bottom-6 -right-6 w-24 h-24 bg-purple-500/10 rounded-full blur-xl group-hover:bg-cyan-500/20 transition-all duration-500"
				>
				</div>
				<h2
					class="text-xl font-bold text-white mb-5 flex items-center gap-2"
				>
					<svg
						class="w-5 h-5 text-cyan-400"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
						><path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
						></path></svg
					>
					Mis Hobbies
				</h2>
				<ul class="flex flex-col gap-3 relative z-10">
					{
						identity.hobbies.map((hobby) => (
							<li class="flex items-center gap-3 text-gray-300 py-3 border-b border-gray-800/50 last:border-0 hover:text-white transition-colors duration-300">
								<span class="w-1.5 h-1.5 rounded-full bg-cyan-500 flex-shrink-0 shadow-[0_0_8px_rgba(6,182,212,0.8)]" />
								{hobby}
							</li>
						))
					}
				</ul>
			</div>

			<!-- Skills Section (Full Width across bottom) -->
			<div
				class="md:col-span-3 bg-linear-to-br from-gray-900 to-[#0a0a0a] border border-gray-800 rounded-3xl p-8 lg:p-10 hover:border-cyan-500/30 transition-all duration-500 relative group overflow-hidden"
			>
				<!-- Grid background pattern -->
				<div
					class="absolute inset-0 z-0 opacity-[0.03]"
					style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 24px 24px;"
				>
				</div>

				<div class="relative z-10">
					<div
						class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-8 gap-4"
					>
						<h2
							class="text-2xl font-bold text-white flex items-center gap-3"
						>
							<svg
								class="w-6 h-6 text-cyan-400"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
								><path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
								></path></svg
							>
							Habilidades
						</h2>
						<div
							class="h-px bg-linear-to-r from-cyan-500/50 to-transparent flex-1 ml-4 hidden sm:block"
						>
						</div>
					</div>

					<div class="flex flex-wrap gap-4 text-center sm:text-left">
						{
							skills.map((skill) => (
								<div class="group/skill relative">
									<div class="absolute inset-0 bg-linear-to-r from-cyan-500 to-blue-500 rounded-xl blur opacity-0 group-hover/skill:opacity-30 transition duration-300" />
									<span class="relative flex items-center justify-center px-6 py-3 border border-gray-700/50 rounded-xl bg-gray-900/80 backdrop-blur-sm text-gray-300 font-medium hover:text-white hover:border-cyan-500/50 transition-all duration-300 cursor-default shadow-sm min-w-[120px]">
										{skill}
									</span>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
